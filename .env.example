APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://api.example.com
APP_FORCE_HTTPS=false

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# Prefer file (or redis) over database — DB cache deadlocks under concurrent throttling
CACHE_STORE=file
# CACHE_PREFIX=
TELESCOPE_ENABLED=true

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Comma-separated browser origins allowed to call the API
CORS_ALLOWED_ORIGINS=http://your-frontend-domain.test,http://localhost:3000,https://your-production-domain.com

# Spotify (local OAuth callback must be loopback — Spotify blocks non-HTTPS custom hosts)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:80/spotify/callback
SPOTIFY_FRONTEND_REDIRECT=http://nexus.test/spotify

# ReccoBeats (audio features + recommendations; free, no key)
RECCOBEATS_BASE_URL=https://api.reccobeats.com
RECCOBEATS_TIMEOUT=12
RECCOBEATS_RATE_MAX=30
RECCOBEATS_RATE_DECAY=60
RECCOBEATS_RATE_MAX_WAIT=8

# GitHub App
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY=
GITHUB_REDIRECT_URI=http://127.0.0.1:80/github/callback
GITHUB_FRONTEND_REDIRECT=http://nexus.test/github

SPORTSDB_API_KEY=123
SPORTSDB_BASE_URL=https://www.thesportsdb.com/api/v1/json
SPORTSDB_RATE_MAX=20
SPORTSDB_RATE_DECAY=60
SPORTSDB_RATE_MAX_WAIT=0
SPORTSDB_RATE_RELEASE=45
# One league per fixtures job (safer on small Docker workers).
SPORTSDB_FIXTURE_CHUNK=1
SPORTSDB_FIXTURE_CHAIN_DELAY=1
SPORTSDB_MAX_NEXT_EVENTS=10
SPORTSDB_MAX_PAST_EVENTS=10
SPORTSDB_MAX_DAY_EVENTS=40
SPORTSDB_RESULT_TEXT_MAX=1200

# OpenF1 (historical free; no API key). Live data requires a paid subscription.
OPENF1_BASE_URL=https://api.openf1.org/v1
OPENF1_TIMEOUT=20
OPENF1_RATE_MAX=25
OPENF1_RATE_DECAY=60
OPENF1_RATE_MAX_WAIT=0
OPENF1_RATE_RELEASE=45
OPENF1_LIVE_BUFFER_MIN=35
OPENF1_LOCATION_HZ=0.25
OPENF1_CAR_DATA_HZ=1
OPENF1_TELEMETRY_CHUNK_SEC=180
OPENF1_REPLAY_MAX_DRIVERS=6
OPENF1_REPLAY_STALE_SEC=900

